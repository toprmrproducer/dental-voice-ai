# =============================================================
# Dental Voice AI — Backend Environment Variables
# =============================================================

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGci...your-service-role-key  # Service role key (bypasses RLS)

# --- Twilio ---
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+15551234567  # Your Twilio number for SMS and caller ID

# --- LiveKit ---
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxxxxxxxxx
LIVEKIT_API_SECRET=your_livekit_api_secret
LIVEKIT_SIP_OUTBOUND_TRUNK_ID=ST_xxxxxxxxxxxxxxxx  # LiveKit SIP outbound trunk ID

# --- Twilio SIP (for call transfers) ---
TWILIO_SIP_DOMAIN=your-trunk.pstn.twilio.com  # Twilio Elastic SIP Trunk domain

# --- Dashboard ---
DASHBOARD_URL=http://localhost:3000  # CORS allowed origin

# --- Groq (only needed if backend does LLM calls directly) ---
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# =============================================================
# Dental Voice AI — MASTER Environment Variables Reference
# =============================================================
# Copy this file and fill in your API keys.
# Each service (backend, agent, dashboard) reads from its own .env file,
# but all keys are documented here in one place.
#
# INSTRUCTIONS:
# 1. Fill in every value marked with "REQUIRED"
# 2. Copy the relevant sections to each service's .env file
# 3. Or use this as the single source and symlink/share as needed
# =============================================================


# ========================
# 1. SUPABASE (Database + Storage)
# ========================
# Get these from: https://supabase.com/dashboard/project/pghipeagcnoqpdhfajrw/settings/api
#
# Used by: backend (.env), dashboard (.env.local)

SUPABASE_URL=https://pghipeagcnoqpdhfajrw.supabase.co                  # ✅ Already known
SUPABASE_SERVICE_KEY=                                                    # 🔑 REQUIRED — Service Role key (secret, never expose to frontend)
                                                                         #    Found at: Supabase Dashboard → Settings → API → service_role key
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InBnaGlwZWFnY25vcXBkaGZhanJ3Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzU1NTQ4NjcsImV4cCI6MjA5MTEzMDg2N30.W-A3cV-lSh9qZ7xiB6-i9rf1flSwgjAkYyaYgMLY2Zk   # ✅ Already known


# ========================
# 2. GROQ (AI: Speech-to-Text, LLM, Text-to-Speech)
# ========================
# Get this from: https://console.groq.com/keys
#
# Used by: agent (.env), optionally backend (.env)
# Free tier: 14,400 requests/day — more than enough for testing

GROQ_API_KEY=                                                            # 🔑 REQUIRED — Groq API key (starts with gsk_)


# ========================
# 3. LIVEKIT (Voice/SIP infrastructure)
# ========================
# Get these from: https://cloud.livekit.io → your project → Settings
#
# Used by: backend (.env), agent (.env)

LIVEKIT_URL=                                                             # 🔑 REQUIRED — e.g. wss://your-project.livekit.cloud
LIVEKIT_API_KEY=                                                         # 🔑 REQUIRED — e.g. APIxxxxxxxxx
LIVEKIT_API_SECRET=                                                      # 🔑 REQUIRED — your LiveKit API secret
LIVEKIT_SIP_OUTBOUND_TRUNK_ID=                                           # ⏳ LATER — only needed when setting up outbound calls


# ========================
# 4. TWILIO (Phone numbers + SMS)
# ========================
# Get these from: https://console.twilio.com
#
# Used by: backend (.env)
# NOTE: Only needed for actual phone calls and SMS. Skip for UI-only testing.

TWILIO_ACCOUNT_SID=                                                      # ⏳ LATER — e.g. ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=                                                       # ⏳ LATER — Twilio auth token
TWILIO_PHONE_NUMBER=                                                     # ⏳ LATER — e.g. +18001234567
TWILIO_SIP_DOMAIN=                                                       # ⏳ LATER — e.g. your-trunk.pstn.twilio.com


# ========================
# 5. LOCAL SERVICE URLs (no keys needed)
# ========================
# These are the default localhost addresses when running locally.

BACKEND_URL=http://localhost:8000                                        # ✅ Default — FastAPI backend
DASHBOARD_URL=http://localhost:3000                                      # ✅ Default — Next.js dashboard
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000                             # ✅ Default — Used by Next.js client
DEFAULT_CLINIC_ID=a1b2c3d4-e5f6-4a7b-8c9d-0e1f2a3b4c5d                  # ✅ Default — Demo clinic from seed data


# ========================
# 6. SARVAM AI (Optional: Hindi STT + TTS)
# ========================
# Get this from: https://dashboard.sarvam.ai
#
# Used by: agent (.env)
# If set, the agent uses Sarvam STT (saaras:v3) + TTS (bulbul:v3)
# instead of Groq for speech recognition and synthesis.
# Groq LLM is still used for reasoning.

SARVAM_API_KEY=                                                          # ⏳ OPTIONAL — Sarvam AI API key
SARVAM_LANGUAGE_CODE=hi-IN                                               # ✅ Default — Hindi (options: hi-IN, en-IN, ta-IN, etc.)
SARVAM_VOICE=meera                                                       # ✅ Default — Female Hindi voice
